[0.500, "o", "\u001b[3J\u001b[H\u001b[2J"]
[0.000, "o", "\r\n\u001b[1m  aman agent\u001b[0m\u001b[2m — your AI companion\u001b[0m\r\n"]
[0.416, "o", "\u001b[0;32m  Auto-detected Anthropic API key. Using Claude Sonnet 4.6.\u001b[0m\r\n"]
[0.510, "o", "\u001b[0;32m  ✓\u001b[0m Ecosystem ready: identity, guardrails, workflows \u001b[2m(2,847 tokens)\u001b[0m\r\n"]
[0.410, "o", "\u001b[0;32m  ✓\u001b[0m Connected 45 MCP tools, memory health 94%\r\n"]
[0.410, "o", "\u001b[0;32m  \u001b[1mAman\u001b[0m\u001b[0;32m is ready. Model: \u001b[2mclaude-sonnet-4-6\u001b[0m\r\n"]
[0.507, "o", "\r\n"]
[0.000, "o", "  Type a message, \u001b[2m/help\u001b[0m for commands, or \u001b[2m/quit\u001b[0m to exit.\r\n"]
[0.312, "o", "\u001b[2m  Welcome back. Last time we talked about the auth service.\u001b[0m\r\n"]
[0.311, "o", "\u001b[0;33m  Reminder: Review PR #42 (overdue)\u001b[0m\r\n"]
[0.000, "o", "\u001b[0;33m  Reminder: Deploy auth service to staging (due today)\u001b[0m\r\n"]
[1.509, "o", "\r\n\u001b[0;32mYou > \u001b[0m"]
